# ============================================================
# AI Teaching Assistant 环境配置
# 复制此文件为 .env 或通过环境变量设置
# ============================================================

# DashScope API Key（必填）
# 获取: https://bailian.console.aliyun.com/#/api-key
DASHSCOPE_API_KEY=your-api-key

# Bing Search API Key（可选，用于技术问答搜索）
# BING_SEARCH_API_KEY=your-bing-key

# 前端 API 地址（可选）
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# 管理员账号（可选，首次启动自动创建）
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=admin123456

# JWT 签名密钥（可选）
# AUTH_SECRET=dev-auth-secret-change-me

# 数据库（可选，默认 SQLite: data/app.db）
# DATABASE_URL=sqlite:///data/app.db

# 向量库后端（可选，默认 chroma；设为 milvus 切换至 Milvus）
# VECTOR_BACKEND=chroma

# Milvus 配置（仅 VECTOR_BACKEND=milvus 时需要）
# MILVUS_URI=http://127.0.0.1:19530
# MILVUS_COLLECTION=agent
